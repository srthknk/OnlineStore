{
  "compilerOptions": {
    "paths": {
      "@/*": ["./*"]
    },
    "skipLibCheck": true,
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "moduleResolution": "node"
  },
  "include": ["next.config.mjs", "**/*.js", "**/*.jsx"],
  "exclude": ["node_modules"]
}
