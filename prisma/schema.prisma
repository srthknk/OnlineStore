generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider  = "postgresql"
    url       = env("DATABASE_URL")
}

// Required for creating a User: id, name, email, image, cart (optional JSON string)
model User {
    id    String @id
    name  String
    email String
    image String
    cart  Json   @default("{}")

    // Relations
    ratings     Rating[]
    Address     Address[]
    store       Store?
    deliveryPartner DeliveryPartner?
    buyerOrders Order[]   @relation("BuyerRelation")
    invoices    Invoice[] @relation("InvoiceUser")
}

enum QuantityUnit {
    PIECE
    KG
    GRAM
    LITER
    MILLILITER
    DOZEN
    PACKET
    BOTTLE
    BOX
}

// Required for creating a Product: name, description, mrp, price, images, category, storeId
model Product {
    id              String   @id @default(cuid())
    name            String
    description     String
    mrp             Float
    price           Float
    images          String[]
    category        String
    inStock         Boolean  @default(true)
    storeId         String
    createdAt       DateTime @default(now())
    updatedAt       DateTime @updatedAt
    totalUnits      Int      @default(0)
    manufacturingDate DateTime?
    expiryDate      DateTime?
    units           String?  // e.g., "500g", "1kg", "1L"
    isOrganic       Boolean  @default(false)
    isVegan         Boolean  @default(false)
    manufacturer    String?

    // Relations
    store           Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
    orderItems      OrderItem[]
    rating          Rating[]
    productVariants ProductVariant[]
    
    @@index([inStock])
    @@index([storeId])
    @@index([category])
    @@index([createdAt])
    @@index([isOrganic])
}

// Product Variant for quantity/weight options
model ProductVariant {
    id              String       @id @default(cuid())
    productId       String
    quantityUnit    QuantityUnit
    quantity        String       // Display value like "500", "1", "2"
    totalUnits      Int
    availableUnits  Int
    createdAt       DateTime     @default(now())
    updatedAt       DateTime     @updatedAt

    // Relations
    product         Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

    @@unique([productId, quantityUnit, quantity])
    @@index([productId])
}

enum OrderStatus {
    ORDER_PLACED
    PROCESSING
    SHIPPED
    DELIVERED
    CANCELLED
}

enum DeliveryStatus {
    ASSIGNED       // Order assigned to delivery partner
    PICKED_UP      // Delivery partner picked up the order
    IN_TRANSIT     // Order is on the way
    DELIVERED      // Order delivered successfully
    FAILED         // Delivery failed
}

enum CancellationReason {
    CHANGED_MIND
    FOUND_CHEAPER
    DONT_NEED_ANYMORE
    DELIVERY_LATE
    OTHER_REASON
    OUT_OF_STOCK
    INSUFFICIENT_QUANTITY
    PRODUCT_UNAVAILABLE
    QUALITY_ISSUE
    SELLER_REQUEST
}

enum PaymentMethod {
    COD
    RAZORPAY_CARD
    RAZORPAY_UPI
    RAZORPAY_WALLET
}

enum PaymentStatus {
    PENDING
    SUCCESS
    FAILED
    REFUNDED
}

// Required for creating an Order: total, userId, storeId, addressId, isPaid, paymentMethod, isCouponUsed, coupon (JSON), orderItems (nested)
model Order {
    id                    String                  @id @default(cuid())
    total                 Float
    deliveryCharges       Float                   @default(0)
    status                OrderStatus             @default(ORDER_PLACED)
    userId                String
    storeId               String
    addressId             String
    isPaid                Boolean                 @default(false)
    paymentMethod         PaymentMethod
    paymentStatus         PaymentStatus           @default(PENDING)
    razorpayOrderId       String?                 // Razorpay order ID
    razorpayPaymentId     String?                 // Razorpay payment ID after successful payment
    razorpaySignature     String?                 // Razorpay signature for verification
    createdAt             DateTime                @default(now())
    updatedAt             DateTime                @updatedAt
    isCouponUsed          Boolean                 @default(false)
    coupon                Json                    @default("{}")
    orderItems            OrderItem[]
    isCancelled           Boolean                 @default(false)
    cancellationReason    CancellationReason?
    cancellationDescription String?
    cancelledBy           String?                 // "buyer" or "seller"
    cancelledAt           DateTime?

    // Delivery Partner Assignment
    deliveryPartnerId     String?                 // Assigned delivery partner
    deliveryStatus        DeliveryStatus?         // Status of delivery
    deliveryStartedAt     DateTime?               // When delivery started
    deliveryCompletedAt   DateTime?               // When delivery was completed

    // Relations
    user    User    @relation("BuyerRelation", fields: [userId], references: [id])
    store   Store   @relation(fields: [storeId], references: [id])
    address Address @relation(fields: [addressId], references: [id])
    deliveryPartner DeliveryPartner? @relation(fields: [deliveryPartnerId], references: [id])
    invoice Invoice?
    
    @@index([status])
}

// Required for creating an OrderItem: orderId, productId, quantity, price
model OrderItem {
    orderId          String
    productId        String
    quantity         Int
    price            Float
    selectedVariant  QuantityUnit?

    // Relations
    order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
    product Product @relation(fields: [productId], references: [id])

    @@id([orderId, productId])
}

// Required for creating a Rating: rating, review, userId, productId
model Rating {
    id        String   @id @default(cuid())
    rating    Int
    review    String
    userId    String
    productId String
    orderId   String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

    @@unique([userId, productId, orderId])
}

// Required for creating an Address: userId, name, email, phone, house, area, city, state, district, pin, addressType
model Address {
    id          String   @id @default(cuid())
    userId      String
    name        String
    email       String
    phone       String
    house       String   // House No, Flat, Building Name
    area        String   // Area, Street, Locality
    landmark    String?  // Optional: Nearby Landmark
    city        String   // City / Town / Village
    district    String   // District (from StateDistrict model)
    state       String   // State / UT
    pin         String   // 6-digit PIN code
    country     String   @default("India")
    addressType String   @default("Home") // Home, Work, Other
    isDefault   Boolean  @default(false)
    createdAt   DateTime @default(now())

    // Relations
    Order Order[]
    user  User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    
    @@unique([userId, id]) // Ensure user can have multiple addresses
    @@index([userId])
}

// StateDistrict model for Indian states and their districts
model StateDistrict {
    id        String   @id @default(cuid())
    state     String   // State or Union Territory name
    district  String   // District name
    createdAt DateTime @default(now())

    @@unique([state, district]) // Ensure unique state-district pairs
    @@index([state])
}

// Required for creating a Coupon: code, description, discount, forNewUser, isPublic, expiresAt
model Coupon {
    code        String   @id
    description String
    discount    Float
    forNewUser  Boolean
    forMember   Boolean  @default(false)
    isPublic    Boolean
    expiresAt   DateTime
    createdAt   DateTime @default(now())
}

// Required for creating a Store: userId, name, username, email, contact, logo, description, address (optional: , status, isActive)
model Store {
    id          String   @id @default(cuid())
    userId      String   @unique
    name        String
    description String
    username    String   @unique
    address     String
    status      String   @default("pending")
    isActive    Boolean  @default(false)
    logo        String
    email       String
    contact     String
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt


    Product Product[]
    Order   Order[]
    user    User      @relation(fields: [userId], references: [id])
    announcementStores AnnouncementStore[]
    announcementReads  AnnouncementRead[]
    invoices Invoice[]
    deliveryPartners DeliveryPartner[] @relation("DeliveryPartnerStore")
    
    @@index([isActive])
    @@index([status])
    @@index([userId])
}

// Settings for store customization
model Settings {
    id              String   @id @default("default")
    storeName       String   @default("My Store")
    // Main Banner (Big Banner on Homepage)
    bannerImage1    String   @default("https://images.unsplash.com/photo-1517694712202-14dd9538aa97?w=1200")
    bannerImage2    String   @default("https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=1200")
    bannerImage3    String   @default("https://images.unsplash.com/photo-1491553895911-0055eca6402d?w=1200")
    bannerImage4    String   @default("")
    bannerImage5    String   @default("")
    bannerTitle1    String   @default("Best Products")
    bannerTitle2    String   @default("20% Discount")
    bannerTitle3    String   @default("New Arrivals")
    bannerTitle4    String   @default("")
    bannerTitle5    String   @default("")
    bannerLink1     String   @default("/shop")
    bannerLink2     String   @default("/shop")
    bannerLink3     String   @default("/shop")
    bannerLink4     String   @default("/shop")
    bannerLink5     String   @default("/shop")
    
    // Feature Card 1 (Pharmacy)
    featureCardTitle1       String   @default("Pharmacy at your doorstep!")
    featureCardDesc1        String   @default("Cough syrups, pain relief sprays & more")
    featureCardButton1      String   @default("Order Now")
    featureCardLink1        String   @default("/shop?category=pharmacy")
    featureCardImage1       String   @default("")
    
    // Feature Card 2 (Pet Care)
    featureCardTitle2       String   @default("Pet care supplies at your door")
    featureCardDesc2        String   @default("Food, treats, toys & more")
    featureCardButton2      String   @default("Order Now")
    featureCardLink2        String   @default("/shop?category=petcare")
    featureCardImage2       String   @default("")
    
    // Feature Card 3 (Baby Care)
    featureCardTitle3       String   @default("No time for a diaper run?")
    featureCardDesc3        String   @default("Get baby care essentials")
    featureCardButton3      String   @default("Order Now")
    featureCardLink3        String   @default("/shop?category=baby")
    featureCardImage3       String   @default("")
    
    email           String   @default("contact@example.com")
    phone           String   @default("+1-212-456-7890")
    address         String   @default("794 Francisco, 94102")
    facebookUrl     String   @default("https://www.facebook.com")
    instagramUrl    String   @default("https://www.instagram.com")
    twitterUrl      String   @default("https://twitter.com")
    linkedinUrl     String   @default("https://www.linkedin.com")
    whatsappLink    String   @default("https://wa.me/")
    createdAt       DateTime @default(now())
    updatedAt       DateTime @updatedAt
}

// FAQ model for storing frequently asked questions
model FAQ {
    id        String   @id @default(cuid())
    question  String
    answer    String   @db.Text
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

// Announcement Models for Admin to Store Communication
enum AnnouncementType {
    NORMAL
    URGENT
    HIGHLY_URGENT
}

enum AnnouncementStatus {
    ACTIVE
    ARCHIVED
}

// Announcements created by admin for stores
model Announcement {
    id              String              @id @default(cuid())
    title           String
    content         String              @db.Text           // Preserves formatting and spaces
    type            AnnouncementType    @default(NORMAL)
    createdBy       String              // Admin user ID
    createdAt       DateTime            @default(now())
    updatedAt       DateTime            @updatedAt
    status          AnnouncementStatus  @default(ACTIVE)

    // Relations
    storeAnnouncements  AnnouncementStore[]

    @@index([createdAt])
    @@index([type])
    @@index([status])
}

// Junction table for announcements to multiple stores
model AnnouncementStore {
    id              String    @id @default(cuid())
    announcementId  String
    storeId         String
    createdAt       DateTime  @default(now())

    // Relations
    announcement    Announcement    @relation(fields: [announcementId], references: [id], onDelete: Cascade)
    store           Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
    reads           AnnouncementRead[]

    @@unique([announcementId, storeId])
    @@index([storeId])
    @@index([announcementId])
}

// Track which sellers have read announcements
model AnnouncementRead {
    id                      String    @id @default(cuid())
    announcementStoreId     String
    storeId                 String    // Denormalized for easier querying
    readAt                  DateTime  @default(now())
    dismissedAt             DateTime?
    status                  String    @default("read")  // read, seen, dismissed

    // Relations
    announcementStore       AnnouncementStore @relation(fields: [announcementStoreId], references: [id], onDelete: Cascade)
    store                   Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)

    @@unique([announcementStoreId, storeId])
    @@index([storeId])
    @@index([announcementStoreId])
}

// Invoice model for order invoices
model Invoice {
    id                  String    @id @default(cuid())
    invoiceNumber       String    @unique // Unique invoice number (e.g., INV-2026-001)
    orderId             String    @unique
    userId              String
    storeId             String
    
    // Customer Details
    customerName        String
    customerEmail       String
    customerPhone       String
    
    // Address Details
    deliveryAddress     String    @db.Text
    
    // Invoice Details
    subtotal            Float
    deliveryCharges     Float     @default(0) // Delivery charges
    gst                 Float     @default(18) // GST percentage
    gstAmount           Float
    total               Float
    paymentMethod       String
    isPaid              Boolean   @default(false)
    
    // Dates
    invoiceDate         DateTime  @default(now())
    dueDate             DateTime?
    createdAt           DateTime  @default(now())
    updatedAt           DateTime  @updatedAt
    
    // Relations
    order               Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
    user                User      @relation("InvoiceUser", fields: [userId], references: [id])
    store               Store     @relation(fields: [storeId], references: [id])
    
    @@index([orderId])
    @@index([userId])
    @@index([storeId])
    @@index([invoiceNumber])
}

// Order Settings for Super Admin - manages delivery charges and free delivery threshold
model OrderSettings {
    id                          String    @id @default(cuid())
    minimumAmountForFreeDelivery Float   @default(500) // Amount in rupees
    deliveryCharges             Float   @default(50)  // Delivery charges in rupees
    freeDeliveryMessage         String  @default("Yay! You unlocked free delivery") // Customizable message
    createdAt                   DateTime  @default(now())
    updatedAt                   DateTime  @updatedAt
}

// Alert/Notification Banner for dynamic alerts shown to users
enum AlertType {
    INFO        // General information
    WARNING     // Warning messages
    PROMOTION   // Promotional offers
    URGENT      // Urgent alerts
}

model Alert {
    id          String      @id @default(cuid())
    title       String      // Main message (e.g., "500 Rs Off Today")
    message     String      @db.Text // Detailed message (e.g., "Use code SAVE500 for 500 rs discount")
    type        AlertType   @default(INFO)
    bgColor     String      @default("from-emerald-600 to-green-600") // Tailwind gradient class
    textColor   String      @default("text-white") // Tailwind text color class
    isActive    Boolean     @default(true)
    icon        String?     // Icon emoji or name (e.g., "🎉", "⚠️", "📢")
    priority    Int         @default(1) // Higher number = higher priority (shown first)
    createdBy   String      // Admin user ID
    createdAt   DateTime    @default(now())
    updatedAt   DateTime    @updatedAt
    expiresAt   DateTime?   // Optional expiry date
    
    @@index([isActive])
    @@index([priority])
    @@index([createdAt])
}

// Delivery Partner Status Enum
enum DeliveryPartnerStatus {
    PENDING      // Awaiting admin approval
    APPROVED     // Approved by admin
    REJECTED     // Rejected by admin
    ACTIVE       // Currently active
    INACTIVE     // Temporarily inactive
    SUSPENDED    // Suspended for violations
}

// Delivery Partner Model
model DeliveryPartner {
    id                      String                  @id @default(cuid())
    userId                  String                  @unique
    firstName               String
    lastName                String
    email                   String                  @unique
    phone                   String
    
    // Address
    address                 String                  @db.Text
    photoUrl                String?                 // Registration photo
    
    // Store Assignment
    selectedStoreId         String
    selectedStore           Store                   @relation("DeliveryPartnerStore", fields: [selectedStoreId], references: [id], onDelete: Restrict)
    
    // Status & Approval
    status                  DeliveryPartnerStatus   @default(PENDING)
    approvedAt              DateTime?               // When admin approved
    approvedBy              String?                 // Admin user ID who approved
    rejectionReason         String?                 // If rejected, reason why
    
    // Performance
    totalDeliveries         Int                     @default(0)
    successfulDeliveries    Int                     @default(0)
    averageRating           Float                   @default(5.0)
    
    // Metadata
    createdAt               DateTime                @default(now())
    updatedAt               DateTime                @updatedAt
    
    // Relations
    user                    User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
    assignedOrders          Order[]                 // Orders assigned to this delivery partner
    
    @@index([status])
    @@index([selectedStoreId])
    @@index([email])
    @@index([createdAt])
}
